# Backend Environment Variables Example File

# The environment mode (development, staging, production)
ENVIRONMENT=development

# Optional: Override the SQLite DB URL here if not using the default `openrep.db`
# DATABASE_URL=sqlite:///openrep.db

# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/openrep

# --- Storage Configuration ---
# Storage Provider: "local", "vercel_blob", or "s3"
# STORAGE_PROVIDER=local

# Required if STORAGE_PROVIDER=vercel_blob
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Required if STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=your_s3_bucket_name
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=https://your-custom-s3-endpoint.com

# --- Auth Configuration ---
# Auth provider for this deployment: "local" (default), "google"
# AUTH_PROVIDER=local
# VITE_FRONTEND_BASE_URL=http://localhost:5173

# Required if AUTH_PROVIDER=google
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_ALLOWED_DOMAIN=yourcompany.com

