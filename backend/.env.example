# Backend Environment Variables Example File

# The environment mode (development, staging, production)
ENVIRONMENT=development

# JWT signing secret — REQUIRED in production. Must be a long random string.
# Generate one with: openssl rand -hex 32
SECRET_KEY=CHANGEME_VERY_SECRET

# Optional: Override the SQLite DB URL here if not using the default `openrep.db`
# DATABASE_URL=sqlite:///openrep.db

# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/openrep

# --- CORS Configuration ---
# Comma-separated list of allowed frontend origins (exact match).
# CORS_ORIGINS=http://localhost:5173
# Regex for additional allowed origins (e.g. Vercel preview URLs).
# Defaults to: https://.*\.vercel\.app
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Storage Configuration ---
# Storage Provider: "local", "vercel_blob", or "s3"
# STORAGE_PROVIDER=local

# Required if STORAGE_PROVIDER=vercel_blob
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Required if STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=your_s3_bucket_name
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=https://your-custom-s3-endpoint.com

# --- Auth Configuration ---
# Auth provider for this deployment: "local" (default), "google"
# AUTH_PROVIDER=local
# Public URL of the frontend — used by the backend for OAuth redirects and CORS defaults.
# Despite the VITE_ prefix, this is read by the backend, not the Vite build.
VITE_FRONTEND_BASE_URL=http://localhost:5173

# Required if AUTH_PROVIDER=google
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_ALLOWED_DOMAIN=yourcompany.com

# --- PostgreSQL (Vercel / Supabase pooler workaround) ---
# Some providers give a pooled connection URL that doesn't support migrations.
# Set this to the non-pooling direct URL when needed (e.g. Vercel Postgres).
# POSTGRES_URL_NON_POOLING=postgresql://user:password@db.example.com:5432/openrep

# --- Authoring Coach ---
# Controls whether the authoring quality checker blocks publish or runs in advisory mode.
# "enforce" (default) — blocks publish when readiness_status == "blocked"
# "shadow"            — advisory only; never blocks publish
# AUTHORING_COACH_MODE=enforce

